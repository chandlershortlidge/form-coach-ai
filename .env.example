# Required
OPENAI_API_KEY=sk-your-openai-key

# Optional — enables LangSmith tracing when set
LANGSMITH_API_KEY=

# Comma-separated list of origins permitted by CORS.
# Defaults to http://localhost:5173 (Vite dev server) when unset.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Path to the Chroma persistence directory. Defaults to ./chroma_db.
CHROMA_DIR=./chroma_db
