   "source": [
    "# Router function"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 9,
   "execution_count": 9,
   "id": "62d58469",
   "metadata": {},
   "outputs": [],
   "source": [
    "def route_query(state: GraphState):\n",
    "    # first check: is there a video?\n",
    "    if state[\"user_video\"]:\n",
    "        return \"video_encoder\"\n",
    "    \n",
    "    # no video — ask the LLM which path\n",
    "    route = router_chain.invoke({\"query\": state[\"user_query\"]})\n",
    "    route = route.lower().strip()\n",
    "    \n",
    "    if \"vectorstore\" in route:\n",
    "        return \"vector_db\"\n",
    "    else:\n",
    "        return \"chat_memory\""
   ]
  },
